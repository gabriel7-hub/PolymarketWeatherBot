# Copy to .env and fill in. NEVER commit .env.

# --- Trading wallet (only required for LIVE execution). Put real values in .env,
#     NOT here — .env.example is committed. ---
# Private key of the EOA that controls your Polymarket proxy wallet.
PK=
# Your Polymarket proxy (funder) wallet address, 0x...
POLY_PROXY_ADDRESS=
# Proxy signature scheme: 0=EOA, 1=email/Magic proxy, 2=browser-wallet Safe, 3=...
SIGNATURE_TYPE=2
# CLOB API credentials (derive with: python -m src.polymarket.clob --create-api-key)
CLOB_API_KEY=
CLOB_API_SECRET=
CLOB_API_PASSPHRASE=

# --- Strategy knobs ---
# Minimum modeled edge (model_prob - price) required to take a trade.
MIN_EDGE=0.07
# Fraction of full-Kelly to bet (0.25 = quarter Kelly, conservative).
KELLY_FRACTION=0.25
# Hard cap on stake per market, in USDC.
MAX_STAKE_PER_MARKET=5
# Floor on stake per market, in USDC. Sized tickets below this are dropped.
MIN_STAKE_PER_MARKET=1.5
# Total bankroll the sizing model assumes, in USDC.
BANKROLL=100
# Fraction of bankroll always kept in cash (reserve buffer; 0.10 = keep 10%).
CASH_BUFFER=0.10
# Max fraction of bankroll committed to any single resolution-day's markets, so
# one day can't eat the whole book and starve the next day (0.50 = 50%).
MAX_DAY_FRACTION=0.50
# Paper fills walk the live order book (depth + slippage) vs filling at the quote.
PAPER_DEPTH=1

# DRY_RUN=1 logs orders without sending them. Set to 0 to trade for real.
DRY_RUN=1

# --- Telegram alerts (sent when a paper/live position settles) ---
# Create a bot via @BotFather for the token; get your chat id from @userinfobot.
# Leave blank to disable notifications.
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# --- Tier-1 non-forecast edges (auto-execution gates) ---
# Each is an EXTRA opt-in on top of DRY_RUN + a funded PK. Even with DRY_RUN=0,
# orders are only sent when the matching flag is 1. Default off (simulate).
ARB_EXECUTE=0          # arb_scan.py --execute: auto-take riskless baskets
ARB_MIN_PROFIT=0.02    # min basket edge (Σask vs 1) to act on
ARB_MAX_CAPITAL=200    # max USDC per basket
LP_EXECUTE=0           # lp_bot.py: post two-sided maker quotes
LP_SIZE=50             # shares per maker quote (rewardsMinSize is 50)
LP_EVENTS=             # comma-separated event slugs; blank = our modeled cities

# --- Tier-3 information/speed edges ---
NOWCAST=0              # score same-day markets from the intraday nowcaster (live obs floor)
NOWCAST_RESID_SIGMA=0.6  # °C residual on the remaining-hours max
NOWCAST_SAMPLES=4000   # Monte-Carlo samples for the daily-max distribution
CORR_KELLY=0           # covariance-shrink simultaneous Kelly across correlated bets
CORR_KELLY_RHO=0.3     # assumed cross-bet outcome correlation

# --- Competitor-inspired lanes (see WALLETS.md) ---
PEER_SIGNAL=0          # tag/size signals by proven weather traders' live entries
PEER_WALLETS=0xd8f8c13644ea84d62e1ec88c5d1215e436eb0f11  # comma-sep; default automatedAItradingbot
PEER_LOOKBACK_HOURS=36 # how far back to read peer trades
NO_HARVEST=0           # low-variance sleeve: buy No on near-impossible buckets (day-before)
NO_HARVEST_MAX_P=0.03  # max calibrated P(Yes) to treat a bucket's No as a "favorite"
NO_HARVEST_STAKE=25    # hard USDC cap per no-harvest ticket
ARB_SCAN=1             # surface coherence-arb windows (Σ best-ask(YES)<1) on the dashboard
FORECAST_TTL=5400      # secs before the daemon re-fetches a station's ensemble (90 min; models update ~6h)
